# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vite) — estas variáveis VÃO para o navegador. Use apenas chaves públicas.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-publica"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# Compat (algumas libs/scripts leem sem o prefixo VITE_)
SUPABASE_URL="https://SEU_PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key-publica"

# ─────────────────────────────────────────────────────────────────────────────
# Shopify — SEGREDOS DE BACKEND. NÃO use prefixo VITE_ (vazaria no navegador).
# Estas variáveis NÃO são lidas deste arquivo: são secrets da Edge Function no
# Supabase. Configure com `supabase secrets set CHAVE=valor` (veja README).
# Listadas aqui só para documentação.
# ─────────────────────────────────────────────────────────────────────────────
# Domínio .myshopify.com da loja (sem https://)
SHOPIFY_SHOP=xxxxx.myshopify.com

# Credenciais do app (novo dev dashboard) — o backend troca por um access token temporário
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Alternativa (fallback): token estático da Admin API (shpat_...)
SHOPIFY_ACCESS_TOKEN=

# Versão da Admin API (opcional, default 2024-01)
SHOPIFY_API_VERSION=2024-01
